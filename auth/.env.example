# Database — same PostgreSQL as API
DATABASE_URL=jdbc:postgresql://localhost:5432/blog

# Client secrets — generated values, must match what frontend/agent use
CLIENT_FRONTEND_SECRET=change-me-frontend-secret
CLIENT_AGENT_SECRET=change-me-agent-secret

# JWT
JWT_EXPIRATION_DAYS=30

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.vercel.app

# LinkedIn — Phase 2
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
