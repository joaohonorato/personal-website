# ── Required ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
TAVILY_API_KEY=tvly-...

# ── Blog API ─────────────────────────────────────────────────────────────────
BLOG_API_URL=https://personal-website-production-33a5.up.railway.app

# Token from /api/auth/login (30-day JWT).
# Alternative: set BLOG_EMAIL + BLOG_PASSWORD — server authenticates at startup.
BLOG_ADMIN_TOKEN=

# BLOG_EMAIL=admin@example.com
# BLOG_PASSWORD=yourpassword

# ── Security ─────────────────────────────────────────────────────────────────
# Same value as app.jwt-secret in Spring Boot (application.properties / Railway env).
# If not set, JWT validation is skipped (local dev).
# Only users with role ADMIN or AI_USER can call the agent.
# JWT_SECRET=your-spring-jwt-secret-here

# ── Cover image generation (optional) ────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# CLOUDINARY_CLOUD_NAME=...
# CLOUDINARY_API_KEY=...
# CLOUDINARY_API_SECRET=...
