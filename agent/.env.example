# Anthropic (obrigatório)
ANTHROPIC_API_KEY=sk-ant-...

# Tavily Search (obrigatório) — free tier: 1.000 req/mês
# https://app.tavily.com
TAVILY_API_KEY=tvly-...

# Blog API (obrigatório)
BLOG_API_URL=http://localhost:8080
# Autenticação — se não configurado, o agente pede email e senha no terminal
# BLOG_EMAIL=seu@email.com
# BLOG_PASSWORD=sua-senha
# Alternativa: token JWT fixo (tem precedência se definido)
# BLOG_ADMIN_TOKEN=eyJ...

# Imagem de capa (opcional) — se não configurado, a fase de capa é pulada
# OpenAI DALL-E 3: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# Cloudinary: https://cloudinary.com → Dashboard → Credentials
# CLOUDINARY_CLOUD_NAME=...
# CLOUDINARY_API_KEY=...
# CLOUDINARY_API_SECRET=...
